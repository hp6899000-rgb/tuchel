rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Authenticated users can read/write their own data
    match /applications/{docId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.uid  // own record
        || get(/databases/$(database)/documents/admins/$(request.auth.uid)).exists()  // admin
      );
      allow create: if request.auth != null && (
        request.auth.uid == request.resource.data.uid  // own record
      );
      allow update, delete: if request.auth != null && (
        request.auth.uid == resource.data.uid  // own record
        || get(/databases/$(database)/documents/admins/$(request.auth.uid)).exists()  // admin
      );
    }

    // Admins collection — only existing admins can manage
    match /admins/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == uid  // self-registration
        || get(/databases/$(database)/documents/admins/$(request.auth.uid)).exists()  // existing admin
      );
    }

    // Jobs — readable by all authenticated users, writable by admins
    match /jobs/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/admins/$(request.auth.uid)).exists();
    }

    // Fees — readable by all authenticated users, writable by admins
    match /fees/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/admins/$(request.auth.uid)).exists();
    }

    // Chats — participants can read/write their own chats
    match /chats/{doc} {
      allow read, update: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;
      allow delete: if false;
    }

    // Messages — participants can read, authenticated users can create
    match /messages/{doc} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
